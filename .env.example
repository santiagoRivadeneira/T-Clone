# ─── Frontend ────────────────────────────────────────────────────────────────
# Base URL for the backend API (leave as /api when using Vite proxy or Docker nginx)
VITE_API_URL=/api

# ─── Backend ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/twitter_clon

# Test database (used by vitest — must be a different DB from the dev one)
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/twitter_clon_test

# JWT signing secret — change this to a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret

# Server port
PORT=3000

# Allowed CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:5173

# Node environment: development | production | test
NODE_ENV=development
